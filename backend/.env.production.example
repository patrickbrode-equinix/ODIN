# ─────────────────────────────────────────────────────────────
#  backend/.env.production.example  —  VM / Production
#  All values marked CHANGE_ME must be set before deploying.
# ─────────────────────────────────────────────────────────────

# ── SERVER ────────────────────────────────────────────────────
PORT=5055
NODE_ENV=production

# ── DATABASE ──────────────────────────────────────────────────
# Prefer DATABASE_URL in production for simplicity:
DATABASE_URL=postgresql://prod_user:CHANGE_ME@shift-postgres:5432/oes_merged

# (Alternatively, individual vars — only used when DATABASE_URL is unset)
# DB_HOST=shift-postgres
# DB_PORT=5432
# DB_NAME=oes_merged
# DB_USER=prod_user
# DB_PASSWORD=CHANGE_ME

# ── AUTH ──────────────────────────────────────────────────────
# REQUIRED — app exits if missing in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_256BIT_RANDOM_HEX
JWT_EXPIRES_IN=8h

# ── SECURITY ──────────────────────────────────────────────────
# REQUIRED — app exits if missing in production.
QUEUE_INGEST_KEY=CHANGE_ME_STRONG_RANDOM_KEY

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated; must be your actual frontend domain(s).
CORS_ORIGINS=https://your-domain.com

# ── VITE PROXY (not used in production, nginx handles routing) ─
# In prod, nginx reverse-proxies /api → backend:5055 directly.
# No BACKEND_URL needed here.
