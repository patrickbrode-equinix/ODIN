# ──────────────────────────────────────────────────
# ODIN Teams Bot – Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────────

# ── Server ──
PORT=3978
NODE_ENV=development

# ── Microsoft Bot Registration ──
CLIENT_ID=
CLIENT_PASSWORD=
TENANT_ID=
BOT_TYPE=MultiTenant

# ── ODIN ↔ Bot Security ──
# Shared secret: ODIN sends this to the bot's internal API
BOT_INTERNAL_API_KEY=change-me-to-a-strong-random-key

# Shared secret: Bot sends this to ODIN callbacks
ODIN_SHARED_SECRET=change-me-to-a-strong-random-key

# Base URL of the ODIN backend (for callbacks from the bot)
ODIN_CALLBACK_BASE_URL=http://localhost:5055

# ── Feature Flags ──
ENABLE_SUPERVISOR_APPROVAL=false
ENABLE_GROUP_NOTIFICATIONS=true
ENABLE_DIRECT_NOTIFICATIONS=true

# ── Microsoft Graph (proactive messaging via email) ──
# Register an App Registration in Azure AD with Application permissions:
#   User.Read.All, TeamsAppInstallation.ReadWriteForUser.All, Chat.Create, ChatMessage.Send
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
# Teams App ID from the tenant app catalog (NOT the Azure App Registration ID)
# Can also be auto-resolved from TEAMS_APP_ID if set by Teams Toolkit
BOT_APP_ID=

# ── Logging ──
# Options: debug | info | warn | error
LOG_LEVEL=info

# ── Microsoft Graph (proactive messaging via email) ──
# Required for sending proactive messages without prior user interaction.
# Register an App Registration in Azure AD with Application permissions:
#   User.Read.All, TeamsAppInstallation.ReadWriteForUser.All, Chat.Create, ChatMessage.Send
# Then grant admin consent.
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
# Teams App ID from the tenant app catalog (NOT the Azure App Registration ID)
BOT_APP_ID=

# ── Debug / Local Testing (remove in production!) ──
# Auto-links first Playground user to this employee ID on first message.
# DEBUG_FALLBACK_EMPLOYEE_ID=emp-123
