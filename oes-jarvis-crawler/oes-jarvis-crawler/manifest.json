{
  "manifest_version": 3,
  "name": "OES Jarvis Queue Crawler",
  "version": "1.0.1",
  "description": "Extracts SmartHands, TroubleTickets and CC Installs and uploads them to local DB.",
  "permissions": [
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://jarvis-emea.equinix.com/*",
    "http://127.0.0.1:5055/*",
    "http://127.0.0.1:8001/*",
    "http://localhost:5055/*",
    "http://localhost:8001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jarvis-emea.equinix.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}