{
  "manifest_version": 3,
  "name": "OES Jarvis Queue Crawler",
  "version": "1.3.0",
  "description": "Extracts SmartHands, TroubleTickets, CC Installs and Deinstalls and uploads them to ODIN (configurable target URL). Supports queue selection, backend preflight, and robust wait logic.",
  "permissions": [
    "alarms",
    "tabs",
    "scripting",
    "activeTab",
    "storage",
    "power"
  ],
  "host_permissions": [
    "https://jarvis-emea.equinix.com/*",
    "http://127.0.0.1:5055/*",
    "http://127.0.0.1:8001/*",
    "http://localhost:5055/*",
    "http://localhost:8001/*",
    "http://localhost:8000/*",
    "http://fr2lxcops01.corp.equinix.com/*",
    "http://fr2lxcops01.corp.equinix.com:8080/*",
    "http://fr2lxcops01.corp.equinix.com:8001/*",
    "https://eqx-portal.corp.equinix.com/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jarvis-emea.equinix.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}