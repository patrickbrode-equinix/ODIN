# ─────────────────────────────────────────────────────────────────────────────
#  ODIN - PRODUCTION ENVIRONMENT TEMPLATE (.env)
# ─────────────────────────────────────────────────────────────────────────────
#  Copy these to Portainer Stack "Environment variables"
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE (Postgres)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=odin
DB_USER=odin_user
DB_PASSWORD=ChangeMe_StrongPassword_123!

# ── BACKEND (Node.js)
NODE_ENV=production
PORT=8001
JWT_SECRET=ChangeMe_Generate_A_Random_String_Here
JWT_EXPIRES_IN=24h
CORS_ORIGINS=http://localhost:8000
QUEUE_INGEST_KEY=ChangeMe_ServiceToken

# ── FRONTEND (Vite / Express)
# VITE_API_BASE_URL is usually "/api" in production (handled by proxy)
VITE_API_BASE_URL=/api

# ── PGADMIN (Optional)
PGADMIN_EMAIL=admin@odin.local
PGADMIN_PASSWORD=ChangeMe_AdminPassword_123!
