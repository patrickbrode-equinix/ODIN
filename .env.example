# ─────────────────────────────────────────────────────────────
#  .env.example (GLOBAL / PORTAINER)
#  Copy these keys and values into the Portainer "Env" section for production.
#  DO NOT use this exact file directly in production! Change the secure values!
# ─────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
DB_HOST=postgres
DB_NAME=odin
DB_USER=odin_admin
# REQUIRED: Set a strong unique password (16+ chars, no @ or $ which can break URL escaping)
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
DB_PORT=5432

# ── PGADMIN ───────────────────────────────────────────────────
PGADMIN_EMAIL=admin@your-domain.com
PGADMIN_PASSWORD=YOUR_SECURE_PGADMIN_PASSWORD

# ── BACKEND CORE ──────────────────────────────────────────────
PORT=8001
NODE_ENV=production

# ── FRONTEND CORE ─────────────────────────────────────────────
# DO NOT set VITE_API_BASE_URL in Portainer stack env vars.
# docker-compose.yml hardcodes the build arg as "/api" — container proxy mode.
# Only set this for external / domain-based deploys where the proxy is NOT used.
# VITE_API_BASE_URL=

# ── AUTH (Required for production safety) ─────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_SECURE_RANDOM_UUID_STRING
JWT_EXPIRES_IN=8h

# ── SECURITY (Ingest / Dashboard Access) ──────────────────────
# Required by the Chrome Extension / Crawler to ingest shifts
QUEUE_INGEST_KEY=YOUR_SECURE_CRAWLER_KEY

# Comma-separated allowed URLs for the UI (No trailing slash)
# Replace <VM_IP> with the actual Oracle Linux VM IP. Port 8080 = ODIN frontend host port.
# Port 8000 is reserved by Portainer/Chisel — do NOT use it here.
CORS_ORIGINS=http://<VM_IP>:8080

# ── MICROSOFT TEAMS (Optional — leave blank to disable) ───────
# Incoming Webhook URL from a Teams channel connector.
# Leave blank to disable Teams notifications gracefully (no crash).
TEAMS_CHANNEL_WEBHOOK=
# Personal webhook for direct assignment notifications (optional)
TEAMS_PERSONAL_WEBHOOK=
