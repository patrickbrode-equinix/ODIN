# ─────────────────────────────────────────────────────────────
#  backend/.env.example  —  copy to backend/.env and edit.
#  Used for: LOCAL DEV (no Docker)
# ─────────────────────────────────────────────────────────────

# ── SERVER ────────────────────────────────────────────────────
PORT=5055
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────────
# Option 1 (preferred): single connection URL
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/oes_merged

# Option 2: individual vars (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oes_merged
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ── AUTH ──────────────────────────────────────────────────────
# REQUIRED in production (app exits if missing).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-only-insecure-secret
JWT_EXPIRES_IN=8h

# ── SECURITY ──────────────────────────────────────────────────
# REQUIRED in production (app exits if missing).
QUEUE_INGEST_KEY=CHANGE_ME_DEV_KEY

# ── PGADMIN (Docker Compose) ──────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated for multiple origins: "https://a.com,https://b.com"
CORS_ORIGINS=http://localhost:5173

# ── VITE DEV PROXY ────────────────────────────────────────────
# Read by vite.config.ts in the frontend — points dev proxy at backend.
# Change to http://backend:5055 when running inside Docker.
BACKEND_URL=http://127.0.0.1:5055
